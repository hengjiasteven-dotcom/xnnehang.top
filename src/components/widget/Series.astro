---
import I18nKey from '../../i18n/i18nKey'
import { i18n } from '../../i18n/translation'
import { getSeriesList } from '../../utils/content-utils'
import { getSeriesUrl } from '../../utils/url-utils'
import ButtonLink from '../control/ButtonLink.astro'
import WidgetLayout from './WidgetLayout.astro'

const seriesList = await getSeriesList()

const COLLAPSED_HEIGHT = '7.5rem'
const COLLAPSE_THRESHOLD = 5

const isCollapsed = seriesList.length >= COLLAPSE_THRESHOLD

interface Props {
  class?: string
  style?: string
}
const className = Astro.props.class
const style = Astro.props.style
---

<WidgetLayout
  name={i18n(I18nKey.series)}
  id="series"
  isCollapsed={isCollapsed}
  collapsedHeight={COLLAPSED_HEIGHT}
  class={className}
  style={style}
>
  {
    seriesList.map((s) => (
      <ButtonLink
        url={getSeriesUrl(s.name)}
        badge={String(s.posts.length)}
        label={`View all posts in the ${s.name.trim()} series`}
      >
        {s.name.trim()}
      </ButtonLink>
    ))
  }
</WidgetLayout>
