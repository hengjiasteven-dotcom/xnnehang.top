---
import path from 'node:path'
import License from '@components/misc/License.astro'
import Markdown from '@components/misc/Markdown.astro'
import I18nKey from '@i18n/i18nKey'
import { i18n } from '@i18n/translation'
import MainGridLayout from '@layouts/MainGridLayout.astro'
import { getSortedPosts } from '@utils/content-utils'
import { buildTfidfIndex, getRelatedByTfidf } from '@utils/tfidf'
import { buildWikiGraphWithTitles } from '@utils/wikilinks'
import { serializeWikiGraphWithTitles, getMiniGraph } from '@utils/graph-serialize'
import { getDir, getPostUrlBySlug, getSeriesUrl } from '@utils/url-utils'
import { Icon } from 'astro-icon/components'
import { licenseConfig } from 'src/config'
import ImageWrapper from '../../components/misc/ImageWrapper.astro'
import GraphView from '../../components/GraphView.svelte'
import PostMetadata from '../../components/PostMeta.astro'
import { profileConfig, siteConfig } from '../../config'
import { formatDateToYYYYMMDD } from '../../utils/date-utils'
import { render } from 'astro:content'
import type { CollectionEntry } from 'astro:content'

// Enriched related post with cover image
type RelatedPost = { slug: string; data: CollectionEntry<'posts'>['data']; firstImage: string }

export async function getStaticPaths() {
  const blogEntries = await getSortedPosts()
  const tfidfIndex = await buildTfidfIndex()
  const { graph: wikiGraph, slugToTitle } = await buildWikiGraphWithTitles()
  const serializedGraph = serializeWikiGraphWithTitles(wikiGraph, slugToTitle)

  const allPosts = blogEntries.map((post) => ({
    slug: post.id,
    data: post.data,
  }))

  return Promise.all(blogEntries.map(async (entry) => {
    const relatedPosts = getRelatedByTfidf(entry.id, tfidfIndex, 5)
    const miniGraphData = getMiniGraph(serializedGraph, entry.id)

    // Enrich related posts with firstImage from rendered body
    const relatedWithImg = await Promise.all(relatedPosts.map(async (rp) => {
      const full = blogEntries.find((e) => e.id === rp.slug)
      if (!full) return { ...rp, firstImage: '' }
      const { remarkPluginFrontmatter } = await render(full)
      return { ...rp, firstImage: remarkPluginFrontmatter.firstImage || '' }
    }))

    return {
      params: { slug: entry.id },
      props: { entry, allPosts, relatedPosts: relatedWithImg, miniGraphData },
    }
  }))
}

const { entry, allPosts, relatedPosts, miniGraphData } = Astro.props
const { Content, headings, remarkPluginFrontmatter } = await render(entry)

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'BlogPosting',
  headline: entry.data.title,
  description: entry.data.description || entry.data.title,
  keywords: entry.data.tags,
  author: {
    '@type': 'Person',
    name: profileConfig.name,
    url: Astro.site,
  },
  datePublished: formatDateToYYYYMMDD(entry.data.published),
  inLanguage: entry.data.lang
    ? entry.data.lang.replace('_', '-')
    : siteConfig.lang.replace('_', '-'),
  // TODO include cover image here
}
---

<MainGridLayout
  banner={entry.data.image}
  title={entry.data.title}
  description={entry.data.description}
  lang={entry.data.lang}
  setOGTypeArticle={true}
  headings={headings}
  hideSidebar={true}
>
  <script is:inline slot="head" type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  <div class="relative mb-4 flex w-full overflow-hidden rounded-[var(--radius-large)]">
    <div
      id="post-container"
      class:list={['card-base relative z-10 w-full px-6 pt-6 pb-4 md:px-9', {}]}
    >
      <!-- word count and reading time -->
      <div
        class="onload-animation mb-3 flex flex-row gap-5 text-black/30 transition dark:text-white/30"
      >
        <div class="flex flex-row items-center">
          <div
            class="mr-2 flex h-6 w-6 items-center justify-center rounded-md bg-black/5 text-black/50 transition dark:bg-white/10 dark:text-white/50"
          >
            <Icon name="material-symbols:notes-rounded" />
          </div>
          <div class="text-sm">
            {remarkPluginFrontmatter.words}
            {' ' + i18n(I18nKey.wordsCount)}
          </div>
        </div>
        <div class="flex flex-row items-center">
          <div
            class="mr-2 flex h-6 w-6 items-center justify-center rounded-md bg-black/5 text-black/50 transition dark:bg-white/10 dark:text-white/50"
          >
            <Icon name="material-symbols:schedule-outline-rounded" />
          </div>
          <div class="text-sm">
            {remarkPluginFrontmatter.minutes}
            {
              ' ' +
                i18n(
                  remarkPluginFrontmatter.minutes === 1 ? I18nKey.minuteCount : I18nKey.minutesCount
                )
            }
          </div>
        </div>
      </div>

      <!-- title -->
      <div class="onload-animation relative">
        <div
          data-pagefind-body
          data-pagefind-weight="10"
          data-pagefind-meta="title"
          class="mb-3 block w-full text-3xl font-bold text-black/90 transition before:absolute before:top-[0.75rem] before:left-[-1.125rem] before:h-5 before:rounded-md before:bg-[var(--primary)] md:text-[2.25rem]/[2.75rem] md:before:w-1 dark:text-white/90"
        >
          {entry.data.title}
        </div>
      </div>

      <!-- metadata -->
      <div class="onload-animation">
        <PostMetadata
          class="mb-5"
          published={entry.data.published}
          updated={entry.data.updated}
          tags={entry.data.tags}
          category={entry.data.category}
        />
        {
          !entry.data.image && (
            <div class="mb-5 border-b-[1px] border-dashed border-[var(--line-divider)]" />
          )
        }
      </div>

      <!-- always show cover as long as it has one -->

      {
        entry.data.image && (
          <ImageWrapper
            id="post-cover"
            src={entry.data.image}
            basePath={path.join('content/posts/', getDir(entry.id))}
            class="banner-container onload-animation mb-8 rounded-xl"
          />
        )
      }

      <Markdown class="markdown-content onload-animation mb-6">
        <Content />
      </Markdown>

      {
        licenseConfig.enable && (
          <License
            title={entry.data.title}
            slug={entry.id}
            pubDate={entry.data.published}
            class="license-container onload-animation mb-6 rounded-xl"
          />
        )
      }

      <!-- series navigation -->
      {
        entry.data.series && entry.data.series.length > 0 && (() => {
          const AROUND_WINDOW = 5
          const seriesNames = entry.data.series || []
          return seriesNames.map((seriesName: string) => {
            const seriesPosts = allPosts
              .filter((p: { data: { series: string[] } }) =>
                p.data.series && p.data.series.includes(seriesName),
              )
              .sort((a: { data: { published: Date } }, b: { data: { published: Date } }) => {
                return new Date(a.data.published).getTime() - new Date(b.data.published).getTime()
              })
            const total = seriesPosts.length
            const currentIndex = seriesPosts.findIndex(
              (p: { slug: string }) => p.slug === entry.id,
            )

            // Truncate to show posts around the current one
            const start = Math.max(0, currentIndex - AROUND_WINDOW)
            const end = Math.min(total, currentIndex + AROUND_WINDOW + 1)
            const visiblePosts = seriesPosts.slice(start, end)
            const isTruncated = total > AROUND_WINDOW * 2 + 1

            return (
              <div class="series-nav onload-animation card-base mb-4 rounded-2xl p-5">
                <div class="flex items-center justify-between">
                  <a
                    href={getSeriesUrl(seriesName)}
                    class="text-sm font-bold uppercase tracking-wider text-[var(--primary)] transition hover:opacity-80"
                  >
                    {seriesName}
                  </a>
                  <span class="text-50 text-xs">{i18n(I18nKey.seriesPostCount).replace('{0}', String(total))}</span>
                </div>
                <ol class="mt-3 flex flex-col gap-1.5">
                  {start > 0 && (
                    <li class="text-center text-xs text-neutral-400">
                      <a href={getSeriesUrl(seriesName)} class="hover:text-[var(--primary)]">{i18n(I18nKey.seriesCollapsedPrev).replace('{0}', String(start))}</a>
                    </li>
                  )}
                  {visiblePosts.map((p: { slug: string; data: { title: string } }, i: number) => {
                    const isCurrent = p.slug === entry.id
                    const realIndex = start + i
                    return (
                      <li class:list={[{ 'text-[var(--primary)]': isCurrent }, 'transition']}>
                        <a
                          href={isCurrent ? undefined : getPostUrlBySlug(p.slug)}
                          class:list={[
                            'flex items-center gap-2 rounded-lg px-3 py-1.5 text-sm transition',
                            isCurrent
                              ? 'bg-[var(--primary)]/10 font-medium'
                              : 'hover:bg-black/5 dark:hover:bg-white/5',
                          ]}
                        >
                          <span class="flex h-5 w-5 shrink-0 items-center justify-center rounded-full bg-black/5 text-xs text-black/50 dark:bg-white/10 dark:text-white/60">
                            {realIndex + 1}
                          </span>
                          <span class="truncate text-black/80 dark:text-white/80">{p.data.title}</span>
                          {isCurrent && <span class="ml-auto text-xs opacity-60">· {i18n(I18nKey.seriesCurrentLabel)}</span>}
                        </a>
                      </li>
                    )
                  })}
                  {end < total && (
                    <li class="text-center text-xs text-neutral-400">
                      <a href={getSeriesUrl(seriesName)} class="hover:text-[var(--primary)]">{i18n(I18nKey.seriesCollapsedNext).replace('{0}', String(total - end))}</a>
                    </li>
                  )}
                </ol>
              </div>
            )
          })
        })()
      }

      <!-- related posts -->
      {
        relatedPosts.length > 0 && (
          <section class="related-posts onload-animation mb-4">
            <h2 class="mb-3 text-lg font-bold text-black/90 dark:text-white/90">{i18n(I18nKey.relatedPosts)}</h2>
            <div class="flex flex-col gap-3">
              {relatedPosts.map((p: RelatedPost) => {
                const img = p.firstImage || p.data.image || ''
                return (
                  <a
                    href={getPostUrlBySlug(p.slug)}
                    class="card-base flex items-center gap-4 rounded-xl p-4 transition hover:bg-black/5 active:scale-[0.98] dark:hover:bg-white/5"
                  >
                    {img && (
                      <div class="h-16 w-24 shrink-0 overflow-hidden rounded-lg bg-black/5 dark:bg-white/5">
                        <ImageWrapper
                          src={img}
                          basePath={path.join('content/posts/', getDir(p.slug))}
                          alt=""
                          class="h-full w-full"
                        />
                      </div>
                    )}
                    <div class="flex min-w-0 flex-col gap-0.5">
                      <span class="truncate font-medium leading-snug text-black/80 dark:text-white/80">{p.data.title}</span>
                      <span class="text-50 shrink-0 text-xs">{formatDateToYYYYMMDD(p.data.published)}</span>
                    </div>
                  </a>
                )
              })}
            </div>
          </section>
        )
      }

      <!-- wiki link graph -->
      <section class="wiki-graph onload-animation mb-4">
        <h2 class="mb-3 text-lg font-bold text-black/90 dark:text-white/90">{i18n(I18nKey.graph)}</h2>
        <div class="card-base overflow-hidden rounded-xl">
          <GraphView
            mode="mini"
            currentSlug={entry.id}
            graphData={miniGraphData}
            client:only="svelte"
          />
        </div>
      </section>
    </div>
  </div>

  <div class="mb-4 flex w-full flex-col justify-between gap-4 overflow-hidden md:flex-row">
    <a
      href={entry.data.nextSlug ? getPostUrlBySlug(entry.data.nextSlug) : '#'}
      class:list={[
        'w-full overflow-hidden font-bold active:scale-95',
        { 'pointer-events-none': !entry.data.nextSlug },
      ]}
    >
      {
        entry.data.nextSlug && (
          <div class="btn-card flex h-[3.75rem] w-full max-w-full items-center !justify-start gap-4 rounded-2xl px-4">
            <Icon
              name="material-symbols:chevron-left-rounded"
              class="text-[2rem] text-[var(--primary)]"
            />
            <div class="max-w-[calc(100%_-_3rem)] overflow-hidden overflow-ellipsis whitespace-nowrap text-black/75 transition dark:text-white/75">
              {entry.data.nextTitle}
            </div>
          </div>
        )
      }
    </a>

    <a
      href={entry.data.prevSlug ? getPostUrlBySlug(entry.data.prevSlug) : '#'}
      class:list={[
        'w-full overflow-hidden font-bold active:scale-95',
        { 'pointer-events-none': !entry.data.prevSlug },
      ]}
    >
      {
        entry.data.prevSlug && (
          <div class="btn-card flex h-[3.75rem] w-full max-w-full items-center !justify-end gap-4 rounded-2xl px-4">
            <div class="max-w-[calc(100%_-_3rem)] overflow-hidden overflow-ellipsis whitespace-nowrap text-black/75 transition dark:text-white/75">
              {entry.data.prevTitle}
            </div>
            <Icon
              name="material-symbols:chevron-right-rounded"
              class="text-[2rem] text-[var(--primary)]"
            />
          </div>
        )
      }
    </a>
  </div>
</MainGridLayout>
